<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>io.github.bxwbb</groupId>
    <artifactId>physmc-api</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <name>PhysMC API</name>
    <description>Public API for integrating Bukkit/Paper plugins with PhysMC physics bodies, constraints and contact events.</description>
    <url>https://github.com/bxwbb/PhysMC</url>

    <licenses>
        <license>
            <name>GNU General Public License v3.0</name>
            <url>https://www.gnu.org/licenses/gpl-3.0.en.html</url>
            <distribution>repo</distribution>
        </license>
    </licenses>

    <developers>
        <developer>
            <id>bxwbb</id>
            <name>bxwbb</name>
            <url>https://github.com/bxwbb</url>
        </developer>
    </developers>

    <scm>
        <connection>scm:git:https://github.com/bxwbb/PhysMC.git</connection>
        <developerConnection>scm:git:ssh://git@github.com/bxwbb/PhysMC.git</developerConnection>
        <url>https://github.com/bxwbb/PhysMC</url>
    </scm>

    <properties>
        <java.version>16</java.version>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.source>${java.version}</maven.compiler.source>
        <maven.compiler.target>${java.version}</maven.compiler.target>
        <maven.compiler.release>${java.version}</maven.compiler.release>
        <api.compile.classpath>${env.PHYS_API_COMPILE_CP}</api.compile.classpath>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.joml</groupId>
            <artifactId>joml</artifactId>
            <version>1.10.8</version>
            <scope>provided</scope>
        </dependency>
    </dependencies>

    <build>
        <sourceDirectory>src/main/java</sourceDirectory>
        <resources/>
        <plugins>
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>flatten-maven-plugin</artifactId>
                <version>1.7.3</version>
                <configuration>
                    <flattenMode>oss</flattenMode>
                    <updatePomFile>true</updatePomFile>
                </configuration>
                <executions>
                    <execution>
                        <id>flatten</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>flatten</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>flatten-clean</id>
                        <phase>clean</phase>
                        <goals>
                            <goal>clean</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <version>3.4.0</version>
                <configuration>
                    <skip>true</skip>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.14.0</version>
                <configuration>
                    <release>${java.version}</release>
                    <encoding>${project.build.sourceEncoding}</encoding>
                    <compilerArgs>
                        <arg>-proc:none</arg>
                        <arg>-Xlint:-options</arg>
                        <arg>-classpath</arg>
                        <arg>${project.build.outputDirectory}${path.separator}${api.compile.classpath}${path.separator}${settings.localRepository}/org/joml/joml/1.10.8/joml-1.10.8.jar</arg>
                    </compilerArgs>
                    <includes>
                        <include>com/bxwbb/physmc/api/**/*.java</include>
                    </includes>
                    <excludes>
                        <exclude>com/bxwbb/physmc/api/internal/**/*.java</exclude>
                    </excludes>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-source-plugin</artifactId>
                <version>3.3.1</version>
                <executions>
                    <execution>
                        <id>attach-sources</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>jar-no-fork</goal>
                        </goals>
                        <configuration>
                            <includes>
                                <include>com/bxwbb/physmc/api/**/*.java</include>
                            </includes>
                            <excludes>
                                <exclude>com/bxwbb/physmc/api/internal/**/*.java</exclude>
                            </excludes>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-javadoc-plugin</artifactId>
                <version>3.11.2</version>
                <executions>
                    <execution>
                        <id>attach-javadocs</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>jar</goal>
                        </goals>
                        <configuration>
                            <encoding>${project.build.sourceEncoding}</encoding>
                            <sourcepath>${project.basedir}/src/main/java</sourcepath>
                            <sourceFileIncludes>
                                <sourceFileInclude>com/bxwbb/physmc/api/*.java</sourceFileInclude>
                                <sourceFileInclude>com/bxwbb/physmc/api/event/*.java</sourceFileInclude>
                            </sourceFileIncludes>
                            <sourceFileExcludes>
                                <sourceFileExclude>com/bxwbb/physmc/api/internal/**/*.java</sourceFileExclude>
                            </sourceFileExcludes>
                            <additionalOptions>
                                <additionalOption>-classpath</additionalOption>
                                <additionalOption>${api.compile.classpath}${path.separator}${settings.localRepository}/org/joml/joml/1.10.8/joml-1.10.8.jar</additionalOption>
                            </additionalOptions>
                            <doclint>none</doclint>
                            <windowtitle>PhysMC API ${project.version}</windowtitle>
                            <doctitle>PhysMC API ${project.version}</doctitle>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-gpg-plugin</artifactId>
                <version>3.2.7</version>
                <executions>
                    <execution>
                        <id>sign-artifacts</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>sign</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.sonatype.central</groupId>
                <artifactId>central-publishing-maven-plugin</artifactId>
                <version>0.10.0</version>
                <extensions>true</extensions>
                <configuration>
                    <publishingServerId>central</publishingServerId>
                    <autoPublish>false</autoPublish>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
